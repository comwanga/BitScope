BITCOIN_RPC_HOST=127.0.0.1
APP_VERSION=0.1.0
APP_ENVIRONMENT=development
BITCOIN_RPC_PORT=18443
BITCOIN_RPC_USER=your_rpc_user
BITCOIN_RPC_PASSWORD=your_rpc_password
BITCOIN_RPC_WALLET=
BITCOIN_RPC_TIMEOUT_SECONDS=10
BITCOIN_NETWORK=regtest
BITCOIN_ZMQ_RAWBLOCK=
BITCOIN_ZMQ_RAWTX=
BACKEND_CORS_ORIGINS=http://localhost:3000
BACKEND_TRUSTED_HOSTS=localhost,127.0.0.1
MAX_REQUEST_BODY_BYTES=1048576
# Generate a unique local value and use the same value in frontend/.env.local.
BITSCOPE_LOCAL_ACCESS_TOKEN=replace-with-a-random-local-token
